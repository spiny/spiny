{
  "expo": {
    "name": "Spiny",
    "slug": "spiny",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "spiny",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.spiny.app"
    },
    "android": {
      "package": "com.spiny.app",
      "adaptiveIcon": {
        "backgroundColor": "#19193b",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#19193b",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 160
          }
        }
      ],
      [
        "expo-sqlite",
        {
          "enableFTS": true,
          "useSQLCipher": false
        }
      ],
      "expo-secure-store",
      "expo-localization",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "googleDriveClientId": "",
      "googleDriveClientIdNote": "Public Google OAuth *client id* for the Drive sync connector (Android + iOS native client using PKCE). Per Google 'OAuth 2.0 for Mobile & Desktop Apps' this is a PUBLIC identifier, NOT a secret; never place a client SECRET here. Distributors must register their own OAuth client id and set this value — it ships empty. See docs/technical/sync.md."
    }
  }
}
